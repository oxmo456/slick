{
    "compileOnSave": false,
    "compilerOptions": {
        "baseUrl": "./",
        "strict": true,
        "declaration": true,
        "declarationMap": false,
        "downlevelIteration": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "es2020",
        "module": "es2020"
    },
    "exclude": ["bazel-*", "node_modules", "./**/*.spec.ts"],
    "include": ["./**/*.ts"]
}
