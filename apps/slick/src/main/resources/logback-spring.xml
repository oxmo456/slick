<configuration>
    <springProperty scope="context" name="podName" source="app.pod.name"/>
    <springProperty scope="context" name="podUid" source="app.pod.uid"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} ${podName} %replace(${podUid}){'(.{8}).*','$1'} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
